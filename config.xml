<?xml version='1.0' encoding='utf-8'?>
<widget id="com.dean.soflow.fota" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>SOFLOW FOTA</name>
    <description>BLE FOTA tool for SOFLOW scooters — iOS port of the Android SO ONE-PLUS firmware updater.</description>
    <author email="dean.karpouchtsis@icloud.com" href="https://example.com">Dean</author>
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />

    <!-- iOS platform settings -->
    <platform name="ios">
        <preference name="deployment-target" value="14.0" />
        <preference name="WKWebViewOnly" value="true" />
        <allow-intent href="itms:*" />
        <allow-intent href="itms-apps:*" />
        <!-- Bluetooth usage strings — REQUIRED for App Store / TestFlight -->
        <config-file parent="NSBluetoothAlwaysUsageDescription" target="*-Info.plist">
            <string>This app uses Bluetooth to communicate with your SOFLOW scooter for firmware updates.</string>
        </config-file>
        <config-file parent="NSBluetoothPeripheralUsageDescription" target="*-Info.plist">
            <string>This app uses Bluetooth to communicate with your SOFLOW scooter for firmware updates.</string>
        </config-file>
    </platform>

    <!-- BLE plugin — must match the version Android used (1.4.4) for protocol compatibility -->
    <plugin name="cordova-plugin-ble-central" spec="^1.7.3" />
    <plugin name="cordova-plugin-whitelist" spec="^1.3.5" />
</widget>
